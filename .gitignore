# Histórico do zsh contém comandos potencialmente sensíveis — nunca exportar.
*.zsh_history
.zsh_history
.headroom

# Caches do Python
__pycache__/
*.pyc

# Backups locais
*.backup-*

# Relatório do import-env — específico de cada DESTINO, não viaja no profile.
RELATORIO_IMPORT.md

# Worktrees do Claude Code (diretórios temporários de sessão)
.claude/worktrees/
.vscode

# Backup legível gerado pelo caveman-compress (o CLAUDE.md comprimido é o canônico).
*.original.md
.serena

# Banco de memória local do headroom (gerado em cada máquina)
headroom_memory.db